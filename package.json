{
  "name": "devmind",
  "displayName": "DevMind",
  "publisher": "Dhruva Patil",
  "description": "AI-powered version guard for JavaScript/TypeScript — detects deprecated API usage based on your installed library versions.",
  "version": "0.0.1",
  "engines": { "vscode": "^1.109.0" },
  "categories": ["Linters", "Other"],
  "activationEvents": [
    "onLanguage:typescript",
    "onLanguage:typescriptreact",
    "onLanguage:javascript",
    "onLanguage:javascriptreact",
    "onCommand:devmind.helloWorld",
    "onCommand:devmind.versionGuard.analyzeFile",
    "onCommand:devmind.versionGuard.indexLibrary",
    "onCommand:devmind.versionGuard.showPanel",
    "onCommand:devmind.openChat",
    "onCommand:devmind.explainConflicts",
    "onCommand:devmind.explainConflict",
    "onCommand:devmind.fixNitpicks"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      { "command": "devmind.helloWorld", "title": "DevMind: Hello World" },
      { "command": "devmind.versionGuard.analyzeFile", "title": "DevMind: Analyze Current File", "icon": "$(search)" },
      { "command": "devmind.versionGuard.indexLibrary", "title": "DevMind: Index Library", "icon": "$(cloud-download)" },
      { "command": "devmind.versionGuard.showPanel", "title": "DevMind: Show Indexed Libraries", "icon": "$(shield)" },
      { "command": "devmind.versionGuard.refreshPanel", "title": "DevMind: Refresh Panel", "icon": "$(refresh)" },
      { "command": "devmind.versionGuard.toggle", "title": "DevMind: Toggle Version Guard On/Off", "icon": "$(shield-x)" },
      { "command": "devmind.versionGuard.clearDiagnostics", "title": "DevMind: Clear All Warnings", "icon": "$(clear-all)" },
      { "command": "devmind.testPRSummary.loading", "title": "DevMind: Test PR Summary - Loading" },
      { "command": "devmind.testPRSummary.success", "title": "DevMind: Test PR Summary - Success" },
      { "command": "devmind.testPRSummary.error", "title": "DevMind: Test PR Summary - Error" },
      { "command": "devmind.generatePRSummary", "title": "DevMind: Generate PR Summary" },
      { "command": "devmind.openChat", "title": "DevMind: Open Chat", "icon": "$(comment-discussion)" },
      { "command": "devmind.explainConflicts", "title": "DevMind: Explain Conflicts in File", "icon": "$(search)" },
      { "command": "devmind.explainConflict", "title": "DevMind: Explain This Conflict" },
      { "command": "devmind.nextConflict", "title": "DevMind: Next Conflict" },
      { "command": "devmind.prevConflict", "title": "DevMind: Previous Conflict" },
      { "command": "devmind.fixNitpicks", "title": "DevMind: Fix Nitpicks", "icon": "$(wrench)" }
    ],
    "configuration": {
      "title": "DevMind",
      "properties": {
        "devmind.versionGuard.enabled": { "type": "boolean", "default": true, "description": "Enable DevMind Version Guard — detects deprecated API usage based on your installed library versions." },
        "devmind.versionGuard.minConfidence": { "type": "number", "default": 0.7, "minimum": 0, "maximum": 1, "description": "Minimum confidence score (0–1) required to surface a warning. Higher = fewer but more certain warnings." },
        "devmind.versionGuard.topK": { "type": "number", "default": 8, "minimum": 1, "maximum": 20, "description": "Number of documentation chunks to retrieve per query when analyzing a file." },
        "devmind.versionGuard.projectId": { "type": "string", "default": "", "description": "Project identifier used to scope documentation indexes. Defaults to workspace folder name if empty." },
        "devmind.azure.openaiEndpoint": { "type": "string", "default": "", "description": "Azure OpenAI endpoint URL (e.g. https://my-resource.openai.azure.com)" },
        "devmind.azure.searchEndpoint": { "type": "string", "default": "", "description": "Azure AI Search endpoint URL" },
        "devmind.azure.keyVaultUrl": { "type": "string", "default": "", "description": "Azure Key Vault URL for secret resolution" }
      }
    },
    "keybindings": [
      { "command": "devmind.versionGuard.analyzeFile", "key": "ctrl+shift+v", "mac": "cmd+shift+v", "when": "editorTextFocus" },
      { "command": "devmind.openChat", "key": "ctrl+shift+d", "mac": "cmd+shift+d", "when": "editorFocus" },
      { "command": "devmind.explainConflicts", "key": "ctrl+shift+e", "mac": "cmd+shift+e", "when": "editorFocus" },
      { "command": "devmind.nextConflict", "key": "alt+]", "mac": "alt+]", "when": "editorFocus" },
      { "command": "devmind.prevConflict", "key": "alt+[", "mac": "alt+[", "when": "editorFocus" },
      { "command": "devmind.fixNitpicks", "key": "ctrl+shift+n", "mac": "cmd+shift+n", "when": "editorFocus" }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "test": "mocha",
    "test:unit": "mocha 'src/services/**/*.test.ts'",
    "test:vscode": "vscode-test"
  },
  "devDependencies": {
    "@tanstack/react-query": "^5.90.21",
    "@types/chai": "^4.3.20",
    "@types/dotenv": "^6.1.1",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.15",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/sinon": "^21.0.0",
    "@types/vscode": "^1.109.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "chai": "^4.5.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "mocha": "^11.7.5",
    "prettier": "^3.8.1",
    "sinon": "^21.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0"
  },
  "dependencies": {
    "@azure/ai-projects": "^1.0.1",
    "@azure/core-auth": "^1.10.1",
    "@azure/cosmos": "^4.9.1",
    "@azure/identity": "^4.13.0",
    "@azure/keyvault-secrets": "^4.10.0",
    "@azure/monitor-opentelemetry": "^1.15.1",
    "@azure/search-documents": "^12.2.0",
    "@azure/storage-blob": "^12.31.0",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@octokit/request-error": "^3.0.3",
    "@octokit/rest": "^18.12.0",
    "axios": "^1.13.5",
    "cheerio": "^1.2.0",
    "domhandler": "^5.0.3",
    "dotenv": "^17.3.1",
    "openai": "^6.25.0",
    "tiktoken": "^1.0.22"
  }
}